{
    "version": 2,
    "builds": [
        {
            "src": "index.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "includeFiles": [
                    "system/**",
                    "application/**",
                    "assets/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}